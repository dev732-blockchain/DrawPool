# Polygon RPC (Alchemy)
POLYGON_RPC_HTTP=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_WS=wss://polygon-amoy.g.alchemy.com/v2/YOUR_KEY

# Wallets
HOT_WALLET_PRIVATE_KEY=0x...
HOT_WALLET_ADDRESS=0x...
COLD_WALLET_ADDRESS=0x...

# Alchemy Webhook
ALCHEMY_SIGNING_KEY=your_signing_key

# Token Address (Optional for Mainnet, defaults to real USDT)
USDT_ADDRESS=0x...

# Database URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/drawpool_testnet

# App Port
PORT=3001

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Cold Wallet Address for Admin Auth Signatures
OWNER_ADDRESS=0x...

# Environment flag (set true for Amoy, false/omit for Polygon Mainnet)
IS_TESTNET=true
